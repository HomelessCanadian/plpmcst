# === PLPMCST Configuration ===
# This file is populated automatically by install.sh
# Do not remove any variable, even if left blank.

# --- Minecraft Server ---
SERVER_ROOT="/home/isable/mc_svr/plpmcst/build/exp"
WORLD_NAME="world"

# --- Backup ---
BACKUP_DIR="/home/isable/mc_svr/plpmcst/build/exp/plpmcst/backup"
LOG_DIR="$BACKUP_DIR/logs"
LOG_FILE="$LOG_DIR/backup.log"
HASH_FILE="$LOG_DIR/.last_hash"
HASH_LOG="$LOG_DIR/.hashlog"
INTERVAL_MINUTES=2
RETENTION_LIMIT=3
MAX_DISK=4

# --- Java ---
# DO NOT ALLOCATE ALL YOUR RAM TO MINECRAFT. See notes below.
JAVA_XMS="10G"
JAVA_XMX="10G"
JAVA_BIN="java"
JAVA_FLAGS=""
SERVER_ARGS="nogui"
# Aikar's flags improve garbage collection in Java to improve stability and
# consistency in Minecraft servers. It is recommended to reduce your Xmx/Xms
# by about 1000-1500M to avoid OOMKiller hitting your server, leaving room
# for the OS. Use these flags exactly, only changing Xmx/Xms above.
AIKAR_FLAGS="
-XX:+UseG1GC
-XX:+ParallelRefProcEnabled
-XX:MaxGCPauseMillis=200
-XX:+UnlockExperimentalVMOptions
-XX:+DisableExplicitGC
-XX:+AlwaysPreTouch
-XX:G1NewSizePercent=30
-XX:G1MaxNewSizePercent=40
-XX:G1HeapRegionSize=8M
-XX:G1ReservePercent=20
-XX:G1HeapWastePercent=5
-XX:G1MixedGCCountTarget=4
-XX:InitiatingHeapOccupancyPercent=15
-XX:G1MixedGCLiveThresholdPercent=90
-XX:G1RSetUpdatingPauseTimePercent=5
-XX:SurvivorRatio=32
-XX:+PerfDisableSharedMem
-XX:MaxTenuringThreshold=1
-Dusing.aikars.flags=https://mcflags.emc.gs
-Dterminal.jline=false
"

# --- tmux Sessions ---
MC_SESSION="minecraft"
PLAYIT_SESSION="playit"
ENABLE_PLAYIT="true"

# --- Discord ---
WEBHOOK_URL=""
